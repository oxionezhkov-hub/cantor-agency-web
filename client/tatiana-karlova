<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Татьяна Владимировна Карлова — репетитор по математике</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Work+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
    --ink: #23201C;
    --paper: #F3EFE7;
    --paper-dim: #EAE3D4;
    --red: #A83D2A;
    --pencil: #6B6154;
    --line: #D9CFBC;
    --white: #FFFFFF;

    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'Work Sans', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;

    --radius: 4px;
    --page-padding: 6vw;
    --max: 1180px;
}
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--paper);
    color: var(--ink);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; }
  ::selection { background: var(--red); color: var(--paper); }

  :focus-visible {
    outline: 2px solid var(--red);
    outline-offset: 3px;
  }

  .wrap { max-width: var(--max); margin: 0 auto; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pencil);
    display: block;
    margin-bottom: 1rem;
  }
  .eyebrow.on-dark { color: rgba(243,239,231,0.6); }
  .eyebrow.accent { color: var(--red); }

  h1, h2, h3 {
    font-family: var(--font-display);
    color: var(--ink);
    line-height: 1.12;
    font-weight: 500;
  }
  em {
    font-style: italic;
    color: var(--red);
  }
  .mark {
    position: relative;
    white-space: nowrap;
  }
  .mark::after {
    content: '';
    position: absolute;
    left: -2%; right: -2%;
    bottom: 0.06em;
    height: 0.09em;
    background: var(--red);
    opacity: 0.9;
    border-radius: 2px;
    transform: rotate(-0.6deg);
  }

  section { padding: 6.5rem var(--page-padding); }
  .section-inner { max-width: var(--max); margin: 0 auto; }
  .section-head { max-width: 620px; margin-bottom: 3.25rem; }
  .section-head h2 { font-size: clamp(1.7rem, 2.6vw, 2.35rem); margin-bottom: 0.85rem; }
  .section-head p { color: var(--pencil); font-weight: 300; font-size: 1.02rem; max-width: 540px; }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(243,239,231,0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
    padding: 0 var(--page-padding);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.25rem;
    list-style: none;
  }
  .nav-links a:not(.btn) {
    text-decoration: none;
    color: var(--pencil);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .nav-links a:not(.btn):hover { color: var(--ink); }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.85rem 1.7rem;
    border-radius: var(--radius);
    border: 1.5px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    min-height: 44px;
    line-height: 1.1;
  }
  .btn:hover { background: var(--red); border-color: var(--red); color: var(--paper); }
  .btn-outline {
    background: transparent;
    color: var(--ink);
    border-color: var(--ink);
  }
  .btn-outline:hover { background: var(--ink); color: var(--paper); }
  .btn-sm { padding: 0.6rem 1.15rem; font-size: 0.85rem; min-height: 38px; }
  .btn-on-dark { border-color: var(--paper); background: var(--paper); color: var(--ink); }
  .btn-on-dark:hover { background: var(--red); border-color: var(--red); color: var(--paper); }

  .text-link {
    text-decoration: underline;
    text-decoration-color: var(--line);
    text-underline-offset: 3px;
    text-decoration-thickness: 1.5px;
    transition: text-decoration-color 0.15s;
  }
  .text-link:hover { text-decoration-color: var(--red); }

  /* HERO */
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 4.5rem;
    align-items: center;
    padding: 148px var(--page-padding) 6rem;
    max-width: var(--max);
    margin: 0 auto;
  }
  .hero h1 {
    font-size: clamp(2.3rem, 3.6vw, 3.35rem);
    margin-bottom: 1.4rem;
  }
  .hero-desc {
    color: var(--pencil);
    font-size: 1.08rem;
    font-weight: 300;
    max-width: 480px;
    margin-bottom: 2rem;
    line-height: 1.75;
  }
  .hero-actions { display: flex; flex-direction: column; align-items: flex-start; gap: 1.1rem; }
  .hero-contact-line {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--pencil);
  }
  .hero-contact-line a { color: var(--ink); }

  .hero-photo {
    position: relative;
  }
  .hero-photo-frame {
    border: 1.5px solid var(--ink);
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--paper-dim);
  }
  .hero-photo-frame img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 14%;
  }
  .hero-photo-caption {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--pencil);
    margin-top: 0.65rem;
    text-transform: uppercase;
  }

  /* SCOREBOARD / STATS */
  .scoreboard {
    background: var(--ink);
    color: var(--paper);
  }
  .scoreboard-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .scoreboard-item {
    padding: 0 1.5rem;
    border-left: 1px solid rgba(243,239,231,0.18);
  }
  .scoreboard-item:first-child { border-left: none; padding-left: 0; }
  .scoreboard-num {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 3.6vw, 2.9rem);
    font-weight: 500;
    line-height: 1;
    margin-bottom: 0.6rem;
    color: var(--paper);
  }
  .scoreboard-label {
    font-size: 0.85rem;
    color: rgba(243,239,231,0.62);
    font-weight: 300;
    line-height: 1.4;
  }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4.5rem;
    align-items: start;
  }
  .about-photo-frame {
    border: 1.5px solid var(--ink);
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--paper-dim);
    position: sticky;
    top: 96px;
  }
  .about-photo-frame img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 18%;
  }
  .about-text p {
    color: var(--pencil);
    font-weight: 300;
    margin-bottom: 1.3rem;
    line-height: 1.85;
    font-size: 1.04rem;
  }
  .about-text p strong { color: var(--ink); font-weight: 500; }
  .margin-note {
    border-left: 2px solid var(--red);
    padding-left: 1.4rem;
    margin: 2rem 0;
  }
  .margin-note p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem !important;
    color: var(--ink) !important;
    line-height: 1.55 !important;
    margin: 0 !important;
  }
  .about-cta { margin-top: 1.75rem; }

  /* PAIN POINTS */
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .pain-card {
    background: var(--paper);
    padding: 2.5rem 2.25rem;
  }
  .pain-card h3 {
    font-size: 1.18rem;
    margin-bottom: 1.1rem;
    line-height: 1.3;
  }
  .pain-line { margin-bottom: 0.9rem; }
  .pain-line:last-child { margin-bottom: 0; }
  .pain-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pencil);
    display: block;
    margin-bottom: 0.3rem;
  }
  .pain-line p {
    font-size: 0.94rem;
    color: var(--ink);
    font-weight: 300;
    line-height: 1.6;
  }

  /* HOW LESSONS WORK */
  .lessons-section { background: var(--paper-dim); }
  .lessons-video-frame {
    border: 1.5px solid var(--ink);
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--ink);
    margin-bottom: 3.5rem;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--red);
    margin-bottom: 0.75rem;
  }
  .step-item h4 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.98rem;
    margin-bottom: 0.5rem;
  }
  .step-item p {
    font-size: 0.88rem;
    color: var(--pencil);
    font-weight: 300;
    line-height: 1.55;
  }

  /* SERVICES */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .service-card {
    background: var(--paper);
    padding: 2.25rem 2rem;
  }
  .service-card .eyebrow { margin-bottom: 1.25rem; }
  .service-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.85rem;
  }
  .service-card p {
    font-size: 0.92rem;
    color: var(--pencil);
    font-weight: 300;
    line-height: 1.6;
  }
  .services-note {
    margin-top: 2.5rem;
    color: var(--pencil);
    font-size: 0.95rem;
    font-weight: 300;
  }
  .services-note .text-link { color: var(--ink); }

  /* CONTACT */
  .contact-section { background: var(--ink); color: var(--paper); }
  .contact-grid {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 2.5rem;
  }
  .contact-grid h2 { color: var(--paper); }
  .contact-grid .section-head p { color: rgba(243,239,231,0.62); }
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .contact-list a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--paper);
    font-size: 1.05rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(243,239,231,0.2);
    transition: border-color 0.15s, color 0.15s;
    min-width: 280px;
  }
  .contact-list a:hover { border-color: var(--red); color: var(--red); }
  .contact-list svg { flex-shrink: 0; opacity: 0.85; }

  /* REVIEWS */
  .reviews-photos-wrapper { position: relative; }
  .reviews-photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    max-height: 420px;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }
  .reviews-photos-grid.expanded { max-height: 6000px; }
  .reviews-fade-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 110px;
    background: linear-gradient(to bottom, rgba(243,239,231,0) 0%, var(--paper) 88%);
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  .reviews-photos-grid.expanded ~ .reviews-fade-overlay { opacity: 0; }
  .review-col { display: flex; flex-direction: column; gap: 1px; }
  .review-photo-item { background: var(--paper); line-height: 0; }
  .review-photo-item img { width: 100%; height: auto; }
  .reviews-cta { text-align: center; margin-top: 2.5rem; }
  .reviews-cta.hidden { display: none; }

  /* FORM */
  .form-section {
    background: var(--white);
    border: 1.5px solid var(--ink);
    padding: 3.5rem var(--page-padding);
    max-width: 760px;
    margin: 0 auto;
  }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.55rem; min-width: 0; }
  .form-group.full { grid-column: 1 / -1; }
  .form-group:has(.select-wrap) { grid-column: 1 / -1; }
  label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--pencil);
  }
  input, select, textarea {
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: 0.75rem 0.9rem;
    font-family: var(--font-body);
    font-size: 0.96rem;
    color: var(--ink);
    background: var(--paper);
    transition: border-color 0.15s;
    outline: none;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--ink); }
  .select-wrap { position: relative; width: 100%; min-width: 0; }
  .select-wrap select { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .select-trigger {
    width: 100%;
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: 0.75rem 0.9rem;
    font-family: var(--font-body);
    font-size: 0.96rem;
    color: var(--ink);
    background: var(--paper);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.15s;
  }
  .select-trigger.placeholder { color: var(--pencil); }
  .select-trigger:focus { border-color: var(--ink); }
  .select-trigger.error { border-color: var(--red); }
  .select-trigger-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; flex: 1; }
  .select-chevron {
    flex-shrink: 0; width: 8px; height: 8px;
    border-right: 1.5px solid var(--ink); border-bottom: 1.5px solid var(--ink);
    transform: rotate(45deg) translateY(-2px);
    transition: transform 0.2s;
  }
  .select-wrap.open .select-chevron { transform: rotate(-135deg) translateY(2px); }
  .select-dropdown {
    display: none;
    position: absolute; top: calc(100% + 4px); left: 0; right: 0;
    background: var(--white);
    border: 1.5px solid var(--ink);
    z-index: 50; max-height: 240px; overflow-y: auto;
  }
  .select-wrap.open .select-dropdown { display: block; }
  .select-option {
    display: block; width: 100%; padding: 0.7rem 0.9rem; border: none; background: none;
    font-family: var(--font-body); font-size: 0.94rem; color: var(--ink); text-align: left; cursor: pointer;
  }
  .select-option:hover, .select-option:focus { background: var(--paper-dim); outline: none; }
  .select-option.selected { background: var(--paper-dim); font-weight: 500; }
  textarea { resize: vertical; min-height: 100px; }
  .form-submit { margin-top: 1.75rem; }
  .form-submit .btn { width: 100%; }
  .form-note {
    font-size: 0.8rem;
    color: var(--pencil);
    text-align: center;
    margin-top: 1.1rem;
  }
  .form-alt {
    font-size: 0.9rem;
    color: var(--pencil);
    text-align: center;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .form-alt a { color: var(--ink); }

  /* FOOTER */
  footer { background: var(--ink); color: rgba(243,239,231,0.68); padding: 3rem var(--page-padding) 2rem; }
  .footer-inner {
    max-width: var(--max); margin: 0 auto;
    display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 2rem;
  }
  .footer-logo { font-family: var(--font-display); font-size: 1.2rem; color: var(--paper); font-weight: 600; }
  .footer-sub { font-size: 0.85rem; margin-top: 0.35rem; color: rgba(243,239,231,0.5); }
  .footer-col { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-col a { text-decoration: none; color: rgba(243,239,231,0.68); font-size: 0.9rem; transition: color 0.15s; }
  .footer-col a:hover { color: var(--paper); }
  .footer-label {
    font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(243,239,231,0.4); margin-bottom: 0.3rem;
  }
  .footer-bottom {
    max-width: var(--max); margin: 2.5rem auto 0;
    border-top: 1px solid rgba(243,239,231,0.12);
    padding-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-align: center;
    color: rgba(243,239,231,0.3);
  }

  /* TOAST */
  .toast {
    position: fixed; bottom: 2rem; right: 2rem;
    background: var(--ink); color: var(--paper);
    padding: 1rem 1.5rem; border-radius: var(--radius);
    font-size: 0.9rem; z-index: 999;
    transform: translateY(100px); opacity: 0;
    transition: all 0.3s; pointer-events: none;
    display: flex; align-items: center; gap: 0.6rem;
    border: 1px solid var(--red);
  }
  .toast.show { transform: translateY(0); opacity: 1; }

  /* STICKY CTA (mobile only) */
  .sticky-cta {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 95;
    padding: 0.75rem var(--page-padding) calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: var(--paper);
    border-top: 1px solid var(--line);
    transform: translateY(110%); opacity: 0; pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .sticky-cta.visible { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .sticky-cta .btn { width: 100%; }

  /* BURGER */
  .nav-burger {
    display: none; flex-direction: column; gap: 5px; cursor: pointer;
    padding: 6px; border: none; background: none; z-index: 200;
  }
  .nav-burger span { display: block; width: 22px; height: 1.5px; background: var(--ink); transition: transform 0.3s, opacity 0.3s; }
  .nav-burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    position: fixed; top: 64px; left: 0; right: 0;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    padding: 1.5rem var(--page-padding) 2rem;
    z-index: 99;
    flex-direction: column;
    max-height: calc(100vh - 64px);
    overflow-y: auto;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a:not(.btn) {
    text-decoration: none; color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.25rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }
  .mobile-menu .btn { margin-top: 1.5rem; }
  .mobile-menu-contact {
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--pencil);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mobile-menu-contact a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--line); }

  /* TABLET */
  @media (max-width: 1100px) {
    .hero { gap: 2.5rem; }
    .scoreboard-row { grid-template-columns: repeat(2, 1fr); row-gap: 2rem; }
    .scoreboard-item:nth-child(3) { border-left: none; padding-left: 0; }
    .pain-grid { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); row-gap: 2.5rem; }
  }

  /* MOBILE */
  @media (max-width: 768px) {
    section { padding: 4.5rem var(--page-padding); }
    .section-head { margin-bottom: 2.5rem; }

    .nav-links > *:not(:last-child):not(.nav-burger-item) { display: none; }
    .nav-links { gap: 0.75rem; }
    .nav-burger { display: flex; }
    .nav-cta-desktop { display: none; }

    body.has-sticky-cta { padding-bottom: calc(72px + env(safe-area-inset-bottom, 0px)); }

    .hero {
      grid-template-columns: 1fr;
      padding: 96px var(--page-padding) 3rem;
      gap: 2rem;
    }
    .hero-photo { order: -1; max-width: 320px; margin: 0 auto 0.5rem; }
