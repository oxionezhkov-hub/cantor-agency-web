<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Татьяна Владимировна Карлова — репетитор по математике</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Geologica:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
    --rose-50: #FBF0F0;
    --rose-100: #F5D9D9;
    --rose-200: #EBB9B9;
    --rose-400: #D49191;
    --rose-600: #B86B6B;
    --rose-800: #9A4F4F;
    --peach: #FBE0D2;
    --dusty-rose: #E0B4B4;
    --bg: #FDF9F9;
    --white: #ffffff;
    --text: #3D2C2C;
    --text-soft: #6E5D5D;
    --text-muted: #9E8E8E;
    --border: rgba(154, 79, 79, 0.12);
    --whatsapp: #25D366;
    --whatsapp-dark: #1EBE5A;
    --telegram: #29A9EA;
    --telegram-dark: #1E97D4;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'Geologica', sans-serif;
    --radius: 16px;
    --shadow: 0 4px 32px rgba(154, 79, 79, 0.08);
}
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  :root {
    --page-padding: 5vw;
  }

  /* NAV - glass/semi-transparent */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(253,249,249,0.72);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border-bottom: 1px solid rgba(154,79,79,0.10);
    box-shadow: 0 2px 20px rgba(154,79,79,0.06);
    padding: 0 var(--page-padding);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--rose-600);
    text-decoration: none;
    font-weight: 700;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 400;
    transition: color 0.2s;
    letter-spacing: 0.02em;
  }
  .nav-links a:hover { color: var(--rose-400); }
  .nav-cta {
    background: var(--rose-400);
    color: white !important;
    padding: 0.45rem 1.2rem;
    border-radius: 40px;
    font-weight: 500 !important;
  }
  .nav-cta:hover { background: var(--rose-600) !important; color: white !important; }
  .nav-whatsapp {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--whatsapp);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, background 0.2s;
  }
  .nav-whatsapp:hover { background: var(--whatsapp-dark); transform: scale(1.08); }
  .nav-whatsapp svg { display: block; }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 96px var(--page-padding) 64px;
    gap: 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, var(--rose-50) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -240px; left: -180px;
    width: 560px; height: 560px;
    background: radial-gradient(circle, var(--peach) 0%, transparent 70%);
    opacity: 0.5;
    pointer-events: none;
  }
  .hero-name-tag {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--rose-800);
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 0.6rem;
  }
  .hero-tag {
    display: inline-block;
    background: var(--rose-50);
    color: var(--rose-600);
    border: 1px solid var(--rose-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: tag-blink 2s ease-in-out infinite;
  }
  @keyframes tag-blink {
    0%, 100% {
      color: var(--rose-600);
      border-color: var(--rose-100);
      background: var(--rose-50);
      box-shadow: none;
    }
    50% {
      color: var(--rose-400);
      border-color: var(--rose-400);
      background: rgba(212,145,145,0.14);
      box-shadow: 0 0 14px rgba(212,145,145,0.35);
    }
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: var(--text);
  }
  .hero h1 em {
    color: var(--rose-400);
    font-style: italic;
  }
  .hero-desc {
    color: var(--text-soft);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    max-width: 480px;
    font-weight: 300;
    line-height: 1.8;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--rose-400);
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--rose-600); transform: translateY(-2px); }
  .btn-outline {
    border: 1.5px solid var(--rose-400);
    color: var(--rose-400);
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-block;
    background: transparent;
  }
  .btn-outline:hover { background: var(--rose-50); transform: translateY(-2px); }
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--whatsapp);
    color: white;
    padding: 0.85rem 1.8rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 20px rgba(37,211,102,0.28);
  }
  .btn-whatsapp:hover { background: var(--whatsapp-dark); transform: translateY(-2px); }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .avatar-frame {
    width: 380px; height: 440px;
    background: linear-gradient(145deg, var(--rose-50), var(--rose-100));
    border-radius: 40% 60% 60% 40% / 50% 40% 60% 50%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    position: relative;
    border: 2px solid var(--rose-100);
  }
  .avatar-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }
  .avatar-accent {
    position: absolute;
    left: -34px;
    bottom: 18px;
    width: 132px;
    height: 160px;
    border-radius: 20px;
    overflow: hidden;
    border: 4px solid var(--white);
    box-shadow: var(--shadow);
    transform: rotate(-6deg);
    z-index: 2;
    background: var(--rose-50);
  }
  .avatar-accent img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    display: block;
  }
  .hero-photo-mobile {
    display: none;
    width: min(280px, 72vw);
    margin: 0 auto 1rem;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    border: 2px solid var(--rose-100);
    box-shadow: var(--shadow);
  }
  .hero-photo-mobile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  .stat-badges {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .stat-badges.left { left: -30px; top: 50%; transform: translateY(-50%); }
  .stat-badges.right { right: -30px; top: 40%; transform: translateY(-50%); }
  .stat-badge {
    background: white;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.7rem 1.1rem;
    box-shadow: var(--shadow);
    text-align: center;
    white-space: nowrap;
  }
  .stat-badge strong {
    display: block;
    font-family: var(--font-body);
    font-size: 1.6rem;
    color: var(--rose-400);
    font-weight: 600;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-badge span {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-stats-mobile { display: none; }

  /* SECTION */
  section {
    padding: 96px var(--page-padding);
  }
  .section-label {
    display: inline-block;
    background: var(--rose-50);
    color: var(--rose-600);
    border: 1px solid var(--rose-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .section-title em { color: var(--rose-400); font-style: italic; }
  .section-sub {
    color: var(--text-soft);
    max-width: 540px;
    font-weight: 300;
    font-size: 1.05rem;
  }
  .section-header { margin-bottom: 3.5rem; }
  .form-title em { display: inline; }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 4.5rem;
    align-items: center;
    max-width: 1040px;
    margin: 0 auto;
  }
  .about-photo-wrap {
    position: relative;
  }
  .about-photo-main {
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid var(--rose-100);
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 5;
    background: var(--rose-50);
  }
  .about-photo-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }
  .about-photo-accent {
    position: absolute;
    right: -28px;
    bottom: -28px;
    width: 148px;
    height: 178px;
    border-radius: 18px;
    overflow: hidden;
    border: 4px solid var(--white);
    box-shadow: var(--shadow);
    transform: rotate(5deg);
    background: var(--rose-50);
  }
  .about-photo-accent img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  .about-text h2 { margin-bottom: 1.4rem; }
  .about-text p {
    color: var(--text-soft);
    font-weight: 300;
    margin-bottom: 1.2rem;
    line-height: 1.85;
    font-size: 1.05rem;
  }
  .about-highlight {
    background: var(--rose-50);
    border-left: 3px solid var(--rose-400);
    padding: 1rem 1.5rem;
    border-radius: 0 12px 12px 0;
    margin: 1.5rem 0;
  }
  .about-highlight p {
    color: var(--rose-800) !important;
    font-weight: 400 !important;
    font-size: 1rem !important;
    margin: 0 !important;
    font-style: italic;
  }
  .about-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0.25rem 0 1.5rem;
  }
  .about-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--rose-50);
    border: 1px solid var(--rose-100);
    color: var(--rose-800);
    padding: 0.45rem 0.95rem;
    border-radius: 40px;
    font-size: 0.82rem;
    font-weight: 500;
  }
  .about-cta {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  /* RESULTS STATS */
  .stats-bg {
    background: var(--rose-800);
    color: white;
    padding: 80px var(--page-padding);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 2.5rem;
  }
  .stat-card {
    text-align: center;
    padding: 2rem 1.5rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stat-num {
    font-family: var(--font-body);
    font-size: 3rem;
    font-weight: 600;
    color: var(--peach);
    line-height: 1;
    height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.4;
    font-weight: 300;
    margin: 0;
  }
  .stats-bg .section-title { color: white; }
  .stats-bg .section-sub { color: rgba(255,255,255,0.65); }
  .stats-bg .section-label { background: rgba(255,255,255,0.1); color: var(--peach); border-color: rgba(255,255,255,0.2); }

  /* PAIN POINTS */
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .pain-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.25rem 2rem;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .pain-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    background: linear-gradient(to bottom, var(--rose-400), var(--rose-200));
  }
  .pain-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(154,79,79,0.14);
  }
  .pain-icon {
    width: 54px; height: 54px;
    border-radius: 14px;
    background: var(--rose-50);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 1.4rem;
  }
  .pain-card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    margin-bottom: 1.1rem;
    color: var(--text);
    line-height: 1.35;
  }
  .pain-row {
    display: flex;
    gap: 0.7rem;
    margin-bottom: 0.85rem;
    align-items: flex-start;
  }
  .pain-row:last-child { margin-bottom: 0; }
  .pain-label {
    flex-shrink: 0;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    margin-top: 0.15rem;
    white-space: nowrap;
  }
  .pain-label.problem { background: rgba(194, 68, 66, 0.1); color: #B33D3B; }
  .pain-label.solution { background: rgba(154, 79, 79, 0.1); color: var(--rose-600); }
  .pain-row p {
    font-size: 0.92rem;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.65;
    margin: 0;
  }

  /* SERVICES */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .service-card.featured {
    background: var(--rose-400);
    border-color: var(--rose-400);
    color: white;
  }
  .service-tag {
    display: inline-block;
    background: var(--rose-50);
    color: var(--rose-600);
    font-size: 0.75rem;
    padding: 0.2rem 0.7rem;
    border-radius: 40px;
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }
  .service-card.featured h3 { color: white; }
  .service-card p {
    font-size: 0.9rem;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  .service-card.featured p { color: rgba(255,255,255,0.85); }
  .service-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .service-card.featured .service-footer {
    border-top-color: rgba(255,255,255,0.22);
  }
  .service-footer a {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--rose-600);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .service-footer a:hover { color: var(--rose-800); }
  .service-card.featured .service-footer a { color: white; }
  .service-card.featured .service-tag {
    background: rgba(255,255,255,0.2);
    color: white;
  }
  .services-note {
    text-align: center;
    margin-top: 2.5rem;
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 300;
  }

  /* HOW LESSONS WORK */
  .lessons-section {
    background: var(--rose-50);
    border-radius: 32px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
  .lessons-section .section-header {
    margin-bottom: 2.5rem;
  }
  .lessons-video-wrap {
    width: 100%;
    margin: 0 auto;
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid var(--rose-100);
    box-shadow: var(--shadow);
    background: var(--rose-800);
    aspect-ratio: 16 / 9;
  }
  .lessons-video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #000;
  }
  .lessons-note { display: none; }

  /* HOW IT WORKS */
  .steps-block {
    display: block;
    margin-top: 3rem;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    position: relative;
  }
  .steps-grid::before {
    content: '';
    position: absolute;
    top: 56px;
    left: calc(12.5% + 1rem);
    right: calc(12.5% + 1rem);
    height: 1px;
    background: linear-gradient(to right, var(--rose-100), var(--rose-200), var(--rose-100));
  }
  .step-item { text-align: center; }
  .step-num {
    width: 112px;
    height: 112px;
    background: white;
    border: 2px solid var(--rose-200);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-body);
    font-size: 2.4rem;
    font-weight: 600;
    line-height: 1;
    color: var(--rose-400);
    margin: 0 auto 1.25rem;
    position: relative;
    z-index: 1;
    padding: 0;
    font-variant-numeric: tabular-nums;
    box-sizing: border-box;
  }
  .step-item h4 {
    font-weight: 500;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .step-item p {
    font-size: 0.85rem;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.5;
  }

  /* CONTACT BAND */
  .contact-band {
    background: linear-gradient(135deg, var(--rose-800), #7d4141);
    border-radius: 32px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .contact-band::before {
    content: '';
    position: absolute;
    top: -120px; right: -80px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .contact-band .section-header { margin-bottom: 2.25rem; position: relative; }
  .contact-band .section-title { color: white; }
  .contact-band .section-sub { color: rgba(255,255,255,0.7); margin: 0 auto; }
  .contact-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    position: relative;
  }
  .contact-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.22);
    color: white;
    padding: 0.9rem 1.7rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    backdrop-filter: blur(6px);
    transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .contact-pill:hover { transform: translateY(-3px); background: rgba(255,255,255,0.18); }
  .contact-pill.whatsapp { background: var(--whatsapp); border-color: var(--whatsapp); }
  .contact-pill.whatsapp:hover { background: var(--whatsapp-dark); }
  .contact-pill.telegram { background: var(--telegram); border-color: var(--telegram); }
  .contact-pill.telegram:hover { background: var(--telegram-dark); }
  .contact-pill svg { flex-shrink: 0; }

  /* REVIEWS */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .review-screenshot-card {
    display: block;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  .review-screenshot-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(154,79,79,0.14);
  }
  .review-screenshot-card img {
    width: 100%;
    height: auto;
    display: block;
  }
  .reviews-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
  .reviews-cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .reviews-profi-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--rose-50);
    color: var(--rose-600);
    border: 1px solid var(--rose-100);
    padding: 0.35rem 0.9rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  /* FORM */
  .form-section {
    background: white;
    border-radius: 24px;
    padding: 4rem var(--page-padding);
    border: 1px solid var(--border);
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    min-width: 0;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }
  .form-group.full { grid-column: 1 / -1; }
  .form-group:has(.select-wrap) { grid-column: 1 / -1; }
  label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-soft);
    letter-spacing: 0.02em;
  }
  input, select, textarea {
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--rose-400);
    background: white;
    box-shadow: 0 0 0 3px rgba(212,145,145,0.12);
  }
  .select-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  .select-wrap select {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .select-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .select-trigger.placeholder { color: var(--text-muted); }
  .select-trigger:focus {
    outline: none;
    border-color: var(--rose-400);
    background: white;
    box-shadow: 0 0 0 3px rgba(212,145,145,0.12);
  }
  .select-trigger.error { border-color: #E24B4A; }
  .select-trigger-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    flex: 1;
  }
  .select-chevron {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--rose-400);
    border-bottom: 2px solid var(--rose-400);
    transform: rotate(45deg) translateY(-2px);
    transition: transform 0.2s;
  }
  .select-wrap.open .select-chevron {
    transform: rotate(-135deg) translateY(2px);
  }
  .select-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    width: 100%;
    box-sizing: border-box;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(154,79,79,0.12);
    z-index: 50;
    max-height: 240px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .select-wrap.open .select-dropdown { display: block; }
  .select-option {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
  }
  .select-option:hover,
  .select-option:focus {
    background: var(--rose-50);
    outline: none;
  }
  .select-option.selected {
    background: var(--rose-50);
    color: var(--rose-600);
    font-weight: 500;
  }
  textarea { resize: vertical; min-height: 100px; }
  .form-submit {
    margin-top: 2rem;
    text-align: center;
  }
  .form-submit button {
    background: var(--rose-400);
    color: white;
    border: none;
    padding: 1.05rem 2rem;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    width: 100%;
    max-width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    box-shadow: 0 4px 20px rgba(212,145,145,0.28);
  }
  .form-submit button:hover { background: var(--rose-600); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(212,145,145,0.35); }
  .form-submit button:active { transform: translateY(0); }
  .form-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 1rem;
  }
  .form-alt {
    font-size: 0.9rem;
    color: var(--text-soft);
    text-align: center;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .form-alt a { color: var(--rose-600); font-weight: 500; text-decoration: none; }
  .form-alt a:hover { color: var(--rose-800); }

  /* FOOTER */
  footer {
    background: var(--text);
    color: rgba(255,255,255,0.7);
    padding: 3rem var(--page-padding);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: white;
    font-weight: 700;
  }
  .footer-sub {
    font-size: 0.8rem;
    margin-top: 0.25rem;
    color: rgba(255,255,255,0.45);
  }
  .footer-contact {
    margin-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-contact a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: 0.88rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
  }
  .footer-contact a:hover { color: var(--peach); }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-links a {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--peach); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: 2rem;
    padding-top: 1.5rem;
    font-size: 0.75rem;
    text-align: center;
    color: rgba(255,255,255,0.3);
  }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 2rem; right: 2rem;
    background: var(--rose-800);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    font-size: 0.9rem;
    z-index: 999;
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.3s;
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .toast.show { transform: translateY(0); opacity: 1; }

  /* STICKY CTA - glass */
  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 95;
    padding: 0.75rem var(--page-padding) calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: rgba(253,249,249,0.82);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-top: 1px solid rgba(154,79,79,0.12);
    box-shadow: 0 -4px 24px rgba(154,79,79,0.08);
    transform: translateY(110%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
    display: flex;
    gap: 0.6rem;
  }
  .sticky-cta.visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .sticky-cta-btn {
    display: block;
    flex: 1;
    background: var(--rose-400);
    color: white;
    text-align: center;
    text-decoration: none;
    padding: 0.95rem 1.5rem;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    box-shadow: 0 4px 20px rgba(212,145,145,0.28);
  }
  .sticky-cta-btn:hover { background: var(--rose-600); }
  .sticky-cta-whatsapp {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--whatsapp);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37,211,102,0.32);
  }

  /* FLOATING WHATSAPP */
  .whatsapp-float {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 90;
    width: 58px; height: 58px;
    border-radius: 50%;
    background: var(--whatsapp);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 24px rgba(37,211,102,0.4);
    transition: transform 0.2s, bottom 0.3s;
  }
  .whatsapp-float:hover { transform: scale(1.08); background: var(--whatsapp-dark); }
  body.has-sticky-cta .whatsapp-float { display: none; }

  /* BURGER MENU */
  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 6px;
    border: none;
    background: none;
    z-index: 200;
  }
  .nav-burger span {
    display: block;
    width: 24px; height: 2px;
    background: var(--rose-600);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 64px; left: 0; right: 0;
    background: rgba(253,249,249,0.92);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-bottom: 1px solid rgba(154,79,79,0.10);
    box-shadow: 0 8px 24px rgba(154,79,79,0.08);
    padding: 1.5rem var(--page-padding) 2rem;
    z-index: 99;
    flex-direction: column;
    gap: 0;
    max-height: calc(100vh - 64px);
    overflow-y: auto;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 1.1rem;
    font-weight: 400;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }
  .mobile-menu a:hover { color: var(--rose-400); }
  .mobile-menu-contacts {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .mobile-menu-contacts a {
    border-bottom: none !important;
    display: flex !important;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 40px;
    padding: 0.9rem 1rem !important;
    font-size: 0.95rem !important;
    color: white !important;
    font-weight: 500 !important;
  }
  .mobile-menu-contacts a.mm-whatsapp { background: var(--whatsapp); }
  .mobile-menu-contacts a.mm-telegram { background: var(--telegram); }
  .mobile-menu-contacts a.mm-phone { background: var(--rose-400); }

  /* TABLET 900–1100px */
  @media (max-width: 1100px) {
    .hero { gap: 2rem; padding: 96px 4vw 64px; }
    .avatar-frame { width: 300px; height: 360px; }
    .avatar-accent { width: 100px; height: 122px; left: -18px; bottom: 10px; }
    .stat-badges.left { left: -10px; }
    .stat-badges.right { right: -10px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid::before { display: none; }
    .pain-grid { grid-template-columns: 1fr; }
  }

  /* MOBILE < 768px */
  @media (max-width: 768px) {
    section { padding: 64px var(--page-padding); }

    /* NAV */
    .nav-links { display: none; }
    .nav-burger { display: flex; }
    /* mobile-menu uses glass too */

    body.has-sticky-cta { padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px)); }

    /* HERO */
    .hero-content {
      display: flex;
      flex-direction: column;
    }
    .hero-tag { display: none; }
    .hero-name-tag { order: 1; }
    .hero h1 { order: 2; margin-bottom: 1rem; }
    .hero-desc { order: 3; margin-bottom: 1rem; font-size: 0.92rem; line-height: 1.65; }
    .hero-photo-mobile { order: 4; margin-bottom: 1.25rem; position: relative; }
    .hero-btns { order: 5; margin-bottom: 1.25rem; }
    .hero-stats-mobile { order: 6; }
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 80px var(--page-padding) 40px;
      gap: 0;
    }
    .hero::before, .hero::after { display: none; }
    .hero-photo-mobile { display: block; }
    .hero-visual { display: none; }
    .hero h1 { font-size: clamp(2rem, 8vw, 2.8rem); }
    .hero-desc { font-size: 0.98rem; max-width: 100%; }
    .hero-btns { flex-direction: column; }
    .btn-primary, .btn-outline, .btn-whatsapp { text-align: center; width: 100%; justify-content: center; }

    /* mobile stats strip after hero text */
    .hero-stats-mobile {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      margin-top: 0.5rem;
    }
    .hero-stat-m {
      background: white;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.9rem 1rem;
      text-align: center;
    }
    .hero-stat-m strong {
      display: block;
      font-family: var(--font-body);
      font-size: 1.6rem;
      color: var(--rose-400);
      font-weight: 600;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .hero-stat-m span {
      font-size: 0.72rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    /* ABOUT */
    .about-grid {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }
    .about-text { order: 1; }
    .about-photo-wrap { order: 2; max-width: 320px; margin: 0 auto; width: 100%; }
    .about-photo-accent { width: 108px; height: 130px; right: -14px; bottom: -18px; }

    /* STATS */
    .stats-bg { padding: 56px var(--page-padding); }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .stat-num { font-size: 2.2rem; height: 2.75rem; margin-bottom: 1rem; }
    .stat-card { padding: 1.25rem 1rem; }

    /* PAIN POINTS */
    .pain-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .pain-card { padding: 1.75rem 1.5rem; }

    /* SERVICES */
    .services-grid { grid-template-columns: 1fr; }

    /* CONTACT BAND */
    .contact-links { flex-direction: column; }
    .contact-pill { width: 100%; justify-content: center; }

    /* STEPS — vertical timeline on mobile */
    .steps-block { display: block; margin-top: 2.5rem; }
    .steps-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 100%;
      margin: 0;
    }
    .steps-grid::before {
      display: block;
      left: 27px;
      right: auto;
      top: 28px;
      bottom: 28px;
      width: 2px;
      height: auto;
      transform: none;
      background: linear-gradient(to bottom, var(--rose-100), var(--rose-200), var(--rose-100));
    }
    .step-item {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
      text-align: left;
      padding: 1rem 0;
    }
    .step-num {
      width: 56px;
      height: 56px;
      min-width: 56px;
      font-size: 1.35rem;
      margin: 0;
    }
    .step-content h4 { margin-bottom: 0.35rem; }

    /* REVIEWS */
    .reviews-grid { grid-template-columns: 1fr; }

    .form-title em { display: block; }

    /* FORM */
    .form-section { padding: 2rem 1.25rem; border-radius: 16px; }
    .form-grid { grid-template-columns: 1fr; }
    .form-group.full { grid-column: 1; }
    .form-submit button {
      max-width: 100%;
      padding: 1.1rem 1.5rem;
      font-size: 1rem;
    }
    .select-trigger { font-size: 16px; }

    /* FOOTER */
    .footer-inner { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .footer-links { gap: 1rem; }

    /* WHATSAPP FLOAT */
    .whatsapp-float { right: 16px; bottom: 16px; width: 52px; height: 52px; }

    /* HOW-IT-WORKS section */
    section.lessons-section {
      border-radius: 16px;
      max-width: none;
      margin-left: 1vw;
      margin-right: 1vw;
      width: auto;
    }
    section.contact-band {
      border-radius: 16px;
      max-width: none;
      margin-left: 1vw;
      margin-right: 1vw;
      width: auto;
    }
  }

  /* EXTRA SMALL < 400px */
  @media (max-width: 400px) {
    .hero h1 { font-size: 1.9rem; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .hero-stats-mobile { grid-template-columns: 1fr 1fr; }
  }

  /* REVIEWS — колонки, картинки прижаты друг к другу сверху, с затемнением внизу */
.reviews-photos-wrapper {
  position: relative;
  margin-bottom: 0;
}

.reviews-photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
  align-items: start;
  max-height: 380px;
  overflow: hidden;
  transition: max-height 0.5s ease;
}

.reviews-photos-grid.expanded {
  max-height: 6000px;
}

.reviews-fade-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100px;
  background: linear-gradient(to bottom, rgba(253, 249, 249, 0) 0%, var(--bg) 85%);
  pointer-events: none;
  transition: opacity 0.4s ease;
  z-index: 2;
}

.reviews-photos-grid.expanded ~ .reviews-fade-overlay {
  opacity: 0;
  pointer-events: none;
}

.review-col {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.review-photo-item {
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
  line-height: 0;
}

.review-photo-item:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 32px rgba(154,79,79,0.14);
}

.review-photo-item img {
  width: 100%;
  height: auto;
  display: block;
}

.reviews-cta {
  text-align: center;
  margin-top: 0.25rem;
}

.reviews-cta .btn-outline {
  border-color: var(--rose-400);
  color: var(--rose-400);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  font-weight: 500;
  cursor: pointer;
  padding: 0.7rem 1.8rem;
  border-radius: 40px;
  font-size: 0.95rem;
  transition: all 0.2s;
  display: inline-flex;
