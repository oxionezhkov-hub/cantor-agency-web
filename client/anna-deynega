<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Анна Дейнега — репетитор по сольфеджио и гармонии</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='16' fill='%23232B58'/%3E%3Ctext x='32' y='45' font-family='Georgia,serif' font-size='38' text-anchor='middle' fill='%23E7C878'%3E%E2%99%AA%3C/text%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,700;1,500&family=Geologica:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --note-50: #EEF0F8;
    --note-100: #CDD3EC;
    --note-200: #A9B2DC;
    --note-400: #5C6BB0;
    --note-600: #3C4A8A;
    --note-800: #232B58;
    --gold: #E7C878;
    --amber: #D6A63E;
    --bg: #FAF9F4;
    --white: #ffffff;
    --text: #232130;
    --text-soft: #59566A;
    --text-muted: #8B8798;
    --border: rgba(60,74,138,0.14);
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Geologica', sans-serif;
    --radius: 16px;
    --shadow: 0 4px 32px rgba(60,74,138,0.10);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--note-50); }
  ::-webkit-scrollbar-thumb { background: var(--note-200); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--note-400); }
  * { scrollbar-width: thin; scrollbar-color: var(--note-200) var(--note-50); }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  :root { --page-padding: 5vw; }

  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    box-shadow: none;
    padding: 0 var(--page-padding);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease;
  }
  nav.scrolled {
    background: rgba(250,249,244,0.74);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border-bottom: 1px solid rgba(60,74,138,0.10);
    box-shadow: 0 2px 20px rgba(60,74,138,0.06);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--note-800);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 400;
    transition: color 0.2s;
    letter-spacing: 0.02em;
  }
  .nav-links a:hover { color: var(--amber); }
  .nav-cta {
    background: var(--note-400);
    color: white !important;
    padding: 0.45rem 1.2rem;
    border-radius: 40px;
    font-weight: 500 !important;
  }
  .nav-cta:hover { background: var(--note-600) !important; color: white !important; }

  @keyframes hero-fade-up { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes hero-fade-in { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); } }
  @keyframes hero-slide-in { from { opacity: 0; transform: translateX(32px) translateY(-50%); } to { opacity: 1; transform: translateX(0) translateY(-50%); } }
  @keyframes hero-slide-in-left { from { opacity: 0; transform: translateX(-32px) translateY(-50%); } to { opacity: 1; transform: translateX(0) translateY(-50%); } }

  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 0.95fr 1.15fr;
    align-items: center;
    padding: 96px var(--page-padding) 64px;
    gap: 3rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, var(--note-50) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-tag {
    display: inline-block;
    background: var(--note-50);
    color: var(--note-600);
    border: 1px solid var(--note-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: hero-fade-up 0.6s cubic-bezier(0.22,1,0.36,1) 0.05s both, tag-blink 2s ease-in-out 1.5s infinite;
  }
  @keyframes tag-blink {
    0%, 100% { color: var(--note-600); border-color: var(--note-100); background: var(--note-50); box-shadow: none; }
    50% { color: var(--note-400); border-color: var(--note-400); background: rgba(92,107,176,0.14); box-shadow: 0 0 14px rgba(92,107,176,0.35); }
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4.2vw, 3.8rem);
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: var(--text);
    animation: hero-fade-up 0.7s cubic-bezier(0.22,1,0.36,1) 0.15s both;
  }
  .hero h1 em { color: var(--amber); font-style: italic; }
  .hero-desc {
    color: var(--text-soft);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    animation: hero-fade-up 0.7s cubic-bezier(0.22,1,0.36,1) 0.28s both;
    max-width: 480px;
    font-weight: 300;
    line-height: 1.8;
  }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; animation: hero-fade-up 0.7s cubic-bezier(0.22,1,0.36,1) 0.4s both; }
  .btn-primary {
    background: var(--note-400);
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--note-600); transform: translateY(-2px); }
  .btn-outline {
    border: 1.5px solid var(--note-400);
    color: var(--note-400);
    padding: 0.85rem 2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-block;
  }
  .btn-outline:hover { background: var(--note-50); transform: translateY(-2px); }

  .hero-visual { display: flex; justify-content: center; align-items: center; position: relative; }
  .avatar-frame {
    width: 440px; height: 520px;
    background: linear-gradient(145deg, var(--note-50), var(--note-100));
    border-radius: 40% 60% 60% 40% / 50% 40% 60% 50%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    position: relative;
    border: 2px solid var(--note-100);
    animation: hero-fade-in 1s cubic-bezier(0.22,1,0.36,1) 0.2s both;
    will-change: transform;
  }
  .avatar-photo { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; display: block; }
  .avatar-fallback {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(145deg, var(--note-100), var(--gold));
    font-family: var(--font-display);
    font-size: 3.2rem;
    color: var(--note-800);
    font-weight: 700;
  }
  .hero-photo-mobile {
    display: none;
    width: min(200px, 52vw);
    margin: 0 auto 1rem;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    border: 2px solid var(--note-100);
    box-shadow: var(--shadow);
  }
  .hero-photo-mobile img { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; display: block; }

  .stat-badges { position: absolute; display: flex; flex-direction: column; gap: 1rem; }
  .stat-badges.left { left: -10px; top: 50%; transform: translateY(-50%); animation: hero-slide-in-left 0.7s cubic-bezier(0.22,1,0.36,1) 0.55s both; }
  .stat-badges.right { right: -10px; top: 40%; transform: translateY(-50%); animation: hero-slide-in 0.7s cubic-bezier(0.22,1,0.36,1) 0.65s both; }
  .stat-badge {
    background: white;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.7rem 1.1rem;
    box-shadow: var(--shadow);
    text-align: center;
    white-space: nowrap;
  }
  .stat-badge strong {
    display: block;
    font-family: var(--font-body);
    font-size: 1.5rem;
    color: var(--amber);
    font-weight: 600;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-badge span { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

  .hero-stats-mobile { display: none; }

  section { padding: 96px var(--page-padding); }
  #about { background: var(--note-50); }
  #who-for { background: var(--white); }
  #reviews { background: transparent; }
  #services { background: var(--white); }
  #form { background: linear-gradient(135deg, var(--note-800) 0%, var(--note-600) 60%, var(--note-400) 100%); }
  .section-label {
    display: inline-block;
    background: var(--note-50);
    color: var(--note-600);
    border: 1px solid var(--note-100);
    padding: 0.3rem 1rem;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 3.2vw, 2.7rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .section-title em { color: var(--amber); font-style: italic; }
  .section-sub { color: var(--text-soft); max-width: 560px; font-weight: 300; font-size: 1.05rem; }
  .section-header { margin-bottom: 3.5rem; }
  .form-title em { display: inline; }

  /* ABOUT */
  .about-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 4rem; align-items: center; max-width: 980px; margin: 0 auto; }
  .about-photo-wrap {
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid var(--note-100);
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 5;
    background: var(--note-50);
  }
  .about-photo-wrap img { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; display: block; }
  .about-photo-wrap .avatar-fallback { font-size: 2.6rem; }
  .about-text p { color: var(--text-soft); font-weight: 300; margin-bottom: 1.2rem; line-height: 1.85; font-size: 1.05rem; }
  .about-text p strong { color: var(--text); font-weight: 600; }
  .about-highlight {
    background: var(--note-50);
    border-left: 3px solid var(--amber);
    padding: 1rem 1.5rem;
    border-radius: 0 12px 12px 0;
    margin: 1.5rem 0;
  }
  .about-highlight p { color: var(--note-800) !important; font-weight: 400 !important; font-size: 1rem !important; margin: 0 !important; font-style: italic; }

  /* WHO IT'S FOR */
  .who-for-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: 1080px; margin: 0 auto; }
  .who-for-card { border-radius: 24px; padding: 2.5rem; border: 2px solid var(--note-100); background: var(--note-50); }
  .who-for-card.who-for-gain { background: linear-gradient(145deg, var(--note-600), var(--note-800)); border-color: var(--note-600); }
  .who-for-card h3 { font-family: var(--font-display); font-size: 1.45rem; margin-bottom: 1.5rem; color: var(--note-800); text-wrap: balance; }
  .who-for-card.who-for-gain h3 { color: white; }
  .who-for-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .who-for-list li { display: flex; align-items: flex-start; gap: 0.7rem; color: var(--text-soft); font-weight: 300; line-height: 1.6; }
  .who-for-card.who-for-gain .who-for-list li { color: rgba(255,255,255,0.92); }
  .who-for-check {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px; height: 24px;
    border-radius: 50%;
    background: var(--note-400);
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
  }
  .who-for-card.who-for-gain .who-for-check { background: var(--gold); color: var(--note-800); }

  /* REVIEWS — screenshot masonry, full screenshot visible, click to zoom */
  #reviews .section-header { max-width: 980px; margin-left: auto; margin-right: auto; margin-bottom: 3.5rem; }
  .reviews-grid {
    columns: 2 320px;
    column-gap: 1.75rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .review-screenshot-card {
    display: block;
    break-inside: avoid;
    margin-bottom: 1.5rem;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
    line-height: 0;
  }
  .review-screenshot-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(60,74,138,0.14); }
  .review-screenshot-card img { width: 100%; height: auto; display: block; }
  .review-screenshot-card .photo-fallback {
    width: 100%; min-height: 140px;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--note-50), var(--gold));
    color: var(--note-600);
    font-size: 0.85rem;
    text-align: center;
    padding: 1.5rem;
    line-height: 1.5;
  }

  /* LESSONS / STEPS */
  .lessons-section { background: var(--note-50); border-radius: 32px; max-width: 980px; margin: 3rem auto; width: 100%; }
  .lessons-section .section-header { margin-bottom: 2.5rem; }
  .steps-block { display: block; margin-top: 1rem; }
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; position: relative; }
  .steps-grid::before {
    content: '';
    position: absolute;
    top: 56px;
    left: calc(12.5% + 1rem);
    right: calc(12.5% + 1rem);
    height: 1px;
    background: linear-gradient(to right, var(--note-100), var(--note-200), var(--note-100));
  }
  .step-item { text-align: center; }
  .step-num {
    width: 112px; height: 112px;
    background: white;
    border: 2px solid var(--note-200);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-body);
    font-size: 2.4rem;
    font-weight: 600;
    line-height: 1;
    color: var(--amber);
    margin: 0 auto 1.25rem;
    position: relative;
    z-index: 1;
    padding: 0;
    font-variant-numeric: tabular-nums;
    box-sizing: border-box;
  }
  .step-item h4 { font-weight: 500; font-size: 0.95rem; margin-bottom: 0.5rem; color: var(--text); }
  .step-item p { font-size: 0.85rem; color: var(--text-soft); font-weight: 300; line-height: 1.5; }

  /* SERVICES */
  #services .section-header { max-width: 980px; margin-left: auto; margin-right: auto; }
  .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 980px; margin: 0 auto; }
  .service-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.25rem;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .service-card.featured { background: var(--note-400); border-color: var(--note-400); color: white; }
  .service-tag {
    display: inline-block;
    background: var(--note-50);
    color: var(--note-600);
    font-size: 0.75rem;
    padding: 0.2rem 0.7rem;
    border-radius: 40px;
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .service-card h3 { font-family: var(--font-display); font-size: 1.35rem; margin-bottom: 0.75rem; font-weight: 700; }
  .service-card.featured h3 { color: white; }
  .service-card p { font-size: 0.92rem; color: var(--text-soft); font-weight: 300; line-height: 1.65; margin-bottom: 1.25rem; flex: 1; }
  .service-card.featured p { color: rgba(255,255,255,0.85); }
  .service-card.featured .service-tag { background: rgba(255,255,255,0.2); color: white; }
  .price-line {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .service-card.featured .price-line { border-top-color: rgba(255,255,255,0.22); }
  .price-amount { font-family: var(--font-body); font-weight: 600; font-size: 1.05rem; color: var(--text); font-variant-numeric: tabular-nums; }
  .service-card.featured .price-amount { color: white; }
  .price-duration { font-size: 0.82rem; color: var(--text-muted); font-weight: 400; white-space: nowrap; }
  .service-card.featured .price-duration { color: rgba(255,255,255,0.72); }

  /* FORM */
  #form .section-title, #form .section-sub { color: rgba(255,255,255,0.92); }
  #form .section-title em { color: var(--gold); font-style: italic; }
  #form .section-label { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); }
  .form-section {
    background: white;
    border-radius: 24px;
    padding: 4rem var(--page-padding);
    border: none;
    box-shadow: 0 24px 80px rgba(0,0,0,0.25);
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; min-width: 0; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; min-width: 0; }
  .form-group.full { grid-column: 1 / -1; }
  .form-group:has(.select-wrap) { grid-column: 1 / -1; }
  label { font-size: 0.85rem; font-weight: 500; color: var(--text-soft); letter-spacing: 0.02em; }
  input, select, textarea {
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: white;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--note-400); background: white; box-shadow: 0 0 0 3px rgba(92,107,176,0.14); }
  .select-wrap { position: relative; width: 100%; max-width: 100%; min-width: 0; }
  .select-wrap select { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .select-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: white;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .select-trigger.placeholder { color: var(--text-muted); }
  .select-trigger:focus { outline: none; border-color: var(--note-400); background: white; box-shadow: 0 0 0 3px rgba(92,107,176,0.14); }
  .select-trigger.error { border-color: #E24B4A; }
  .select-trigger-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; flex: 1; }
  .select-chevron {
    flex-shrink: 0;
    width: 10px; height: 10px;
    border-right: 2px solid var(--note-400);
    border-bottom: 2px solid var(--note-400);
    transform: rotate(45deg) translateY(-2px);
    transition: transform 0.2s;
  }
  .select-wrap.open .select-chevron { transform: rotate(-135deg) translateY(2px); }
  .select-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0; right: 0;
    width: 100%;
    box-sizing: border-box;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(60,74,138,0.12);
    z-index: 50;
    max-height: 240px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .select-wrap.open .select-dropdown { display: block; }
  .select-option {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
  }
  .select-option:hover, .select-option:focus { background: var(--note-50); outline: none; }
  .select-option.selected { background: var(--note-50); color: var(--note-600); font-weight: 500; }
  textarea { resize: vertical; min-height: 100px; }
  .form-submit { margin-top: 2rem; text-align: center; }
  .form-submit button {
    background: var(--note-400);
    color: white;
