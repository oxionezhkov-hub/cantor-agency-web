  <img id="reviewLightboxImg" src="" alt="">
</div>

<script>
  // Photos and review screenshots: drop files into the folders below with these exact names to replace placeholders.
  (function loadMedia() {
    const heroPhoto = 'images/anna-deynega/tutor/hero.jpg';
    const aboutPhoto = 'images/anna-deynega/tutor/about.jpg';

    function setImageWithFallback(img, url, initials, loading) {
      if (!img) return;
      img.loading = loading || 'lazy';
      img.onerror = () => {
        if (img.dataset.fallbackApplied) return;
        img.dataset.fallbackApplied = '1';
        const fallback = document.createElement('div');
        fallback.className = 'avatar-fallback';
        fallback.textContent = initials;
        img.replaceWith(fallback);
      };
      img.src = url;
    }

    setImageWithFallback(document.getElementById('hero-tutor-photo'), heroPhoto, 'АД', 'eager');
    setImageWithFallback(document.getElementById('hero-tutor-photo-mobile'), heroPhoto, 'АД', 'eager');
    setImageWithFallback(document.getElementById('about-tutor-photo'), aboutPhoto, 'АД', 'lazy');

    document.querySelectorAll('.review-screenshot-card[data-review]').forEach(el => {
      const n = el.dataset.review;
      const img = document.createElement('img');
      img.loading = 'lazy';
      img.alt = 'Отзыв ученика';
      img.onerror = () => {
        if (img.dataset.fallbackApplied) return;
        img.dataset.fallbackApplied = '1';
        const fallback = document.createElement('div');
        fallback.className = 'photo-fallback';
        fallback.textContent = 'Отзыв ' + n;
        img.replaceWith(fallback);
      };
      img.src = 'images/anna-deynega/reviews/review-' + n + '.jpg';
      el.appendChild(img);
    });
  })();

  // Nav background appears on scroll
  const navEl = document.querySelector('nav');
  function updateNavBg() {
    if (!navEl) return;
    navEl.classList.toggle('scrolled', window.scrollY > 40);
  }
  window.addEventListener('scroll', updateNavBg, { passive: true });
  updateNavBg();

  // Burger menu
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobileMenu');
  burger.addEventListener('click', () => {
    burger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });
  function closeMenu() {
    burger.classList.remove('open');
    mobileMenu.classList.remove('open');
  }

  // Fade-in on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Sticky CTA after hero
  const stickyCta = document.getElementById('stickyCta');
  const heroSection = document.getElementById('home');
  const formSection = document.getElementById('form');

  function updateStickyCta() {
    if (!stickyCta || !heroSection) return;
    if (window.innerWidth > 768) {
      stickyCta.classList.remove('visible');
      document.body.classList.remove('has-sticky-cta');
      return;
    }
    const heroBottom = heroSection.offsetTop + heroSection.offsetHeight - 64;
    const formTop = formSection ? formSection.offsetTop : Infinity;
    const scrolledPastHero = window.scrollY > heroBottom;
    const beforeForm = window.scrollY + window.innerHeight * 0.85 < formTop;
    const show = scrolledPastHero && beforeForm;
    stickyCta.classList.toggle('visible', show);
    document.body.classList.toggle('has-sticky-cta', show);
  }

  window.addEventListener('scroll', updateStickyCta, { passive: true });
  window.addEventListener('resize', updateStickyCta);
  updateStickyCta();

  // Custom selects
  function closeAllSelects() {
    document.querySelectorAll('.select-wrap.open').forEach(w => {
      w.classList.remove('open');
      w.querySelector('.select-trigger')?.setAttribute('aria-expanded', 'false');
    });
  }

  function resetCustomSelect(select) {
    select.selectedIndex = 0;
    const wrap = select.closest('.select-wrap');
    const trigger = wrap?.querySelector('.select-trigger');
    const textSpan = trigger?.querySelector('.select-trigger-text');
    if (trigger && textSpan) {
      textSpan.textContent = select.options[0]?.text || '';
      trigger.classList.add('placeholder');
      trigger.classList.remove('error');
      trigger.setAttribute('aria-expanded', 'false');
    }
    wrap?.querySelectorAll('.select-option').forEach(o => o.classList.remove('selected'));
    wrap?.classList.remove('open');
  }

  document.querySelectorAll('.select-wrap').forEach(wrap => {
    const select = wrap.querySelector('select');
    if (!select || wrap.querySelector('.select-trigger')) return;

    const trigger = document.createElement('button');
    trigger.type = 'button';
    trigger.className = 'select-trigger placeholder';
    trigger.id = select.id + '-trigger';
    trigger.setAttribute('aria-labelledby', select.id + '-label');
    trigger.setAttribute('aria-haspopup', 'listbox');
    trigger.setAttribute('aria-expanded', 'false');

    const label = document.getElementById(select.id + '-label');
    if (label) label.setAttribute('for', trigger.id);

    const textSpan = document.createElement('span');
    textSpan.className = 'select-trigger-text';
    textSpan.textContent = select.options[select.selectedIndex]?.text || '';

    const chevron = document.createElement('span');
    chevron.className = 'select-chevron';
    chevron.setAttribute('aria-hidden', 'true');

    trigger.append(textSpan, chevron);

    const dropdown = document.createElement('div');
    dropdown.className = 'select-dropdown';
    dropdown.setAttribute('role', 'listbox');

    Array.from(select.options).forEach(opt => {
      if (opt.disabled || !opt.value) return;
      const item = document.createElement('button');
      item.type = 'button';
      item.className = 'select-option';
      item.textContent = opt.textContent;
      item.setAttribute('role', 'option');
      item.addEventListener('click', () => {
        select.value = opt.value;
        textSpan.textContent = opt.textContent;
        trigger.classList.remove('placeholder', 'error');
        dropdown.querySelectorAll('.select-option').forEach(o => o.classList.remove('selected'));
        item.classList.add('selected');
        wrap.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      });
      dropdown.appendChild(item);
    });

    dropdown.addEventListener('click', e => e.stopPropagation());

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const wasOpen = wrap.classList.contains('open');
      closeAllSelects();
      if (!wasOpen) {
        wrap.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });

    wrap.append(trigger, dropdown);
  });

  document.addEventListener('click', closeAllSelects);

  // Policy modal
  function openPolicyModal(e) {
    if (e) e.preventDefault();
    document.getElementById('policyModal').classList.add('open');
    document.body.style.overflow = 'hidden';
    return false;
  }
  function closePolicyModal(e) {
    if (e) e.preventDefault();
    document.getElementById('policyModal').classList.remove('open');
    document.body.style.overflow = '';
    return false;
  }

  // Hero parallax on scroll
  (function() {
    const avatarFrame = document.querySelector('.avatar-frame');
    const heroContent = document.querySelector('.hero-content');
    function applyParallax() {
      const y = window.scrollY;
      if (y > window.innerHeight) return;
      if (avatarFrame) avatarFrame.style.transform = `translateY(${y * 0.07}px)`;
      if (heroContent) heroContent.style.transform = `translateY(${y * 0.03}px)`;
    }
    window.addEventListener('scroll', applyParallax, { passive: true });
  })();

  // Review screenshot lightbox
  document.getElementById('reviewsGrid')?.addEventListener('click', (e) => {
    const card = e.target.closest('.review-screenshot-card');
    if (!card) return;
    const img = card.querySelector('img');
    if (!img) return;
    document.getElementById('reviewLightboxImg').src = img.src;
    document.getElementById('reviewLightboxImg').alt = img.alt;
    document.getElementById('reviewLightbox').classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  function closeReviewLightbox(e) {
    if (e) e.preventDefault();
    document.getElementById('reviewLightbox').classList.remove('open');
    document.body.style.overflow = '';
    return false;
  }

  // Form submit
  function submitForm() {
    const fields = ['student_name','student_last','status','subject','phone'];
    let valid = true;
    fields.forEach(id => {
      const el = document.getElementById(id);
      const trigger = el.closest('.select-wrap')?.querySelector('.select-trigger');
      if (!el.value.trim()) {
        if (trigger) trigger.classList.add('error');
        else el.style.borderColor = '#E24B4A';
        valid = false;
      } else {
        if (trigger) trigger.classList.remove('error');
        else el.style.borderColor = '';
      }
    });
    const consent = document.getElementById('consent');
    const consentRow = consent.closest('.consent-row');
    if (!consent.checked) {
      consentRow.classList.add('error');
      valid = false;
    } else {
      consentRow.classList.remove('error');
    }
    if (!valid) {
      alert('Пожалуйста, заполните все обязательные поля и подтвердите согласие на обработку данных.');
      return;
    }
    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 4000);
    document.querySelectorAll('#form input, #form textarea').forEach(el => el.value = '');
    document.querySelectorAll('#form select').forEach(resetCustomSelect);
    consent.checked = false;
  }
</script>
